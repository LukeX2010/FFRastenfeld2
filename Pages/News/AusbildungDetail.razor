@* ── Ausbildung Detail ── *@
@page "/ausbildung/{Slug}"
@inject DataService DS

<PageTitle>@(post?.Titel ?? "Ausbildung") – Freiwillige Feuerwehr Rastenfeld, NÖ</PageTitle>

@if (post is null)
{
    <div class="container" style="padding:4rem 1.5rem;text-align:center"><p>Nicht gefunden. <a href="/ausbildung">← Zurück</a></p></div>
}
else
{
    <PageHero Title="@post.Titel" ParentLabel="Ausbildung" ParentHref="/ausbildung" />
    <div class="site-body container">
        <div class="content-with-sidebar">
            <main class="main-feed">
                <article class="post-detail">
                    <div class="detail-meta">
                        <span class="post-card-kat post-card-kat--ausbildung">Ausbildung</span>
                        <time>@post.Datum.ToString("d. MMMM yyyy")</time>
                    </div>
                    <div class="detail-img"><span class="detail-img-emoji">@post.BildPlaceholder</span><p class="img-caption">Foto: FF Rastenfeld (Platzhalterbild)</p></div>
                    <div class="detail-body"><p>@post.Volltext</p></div>
                    <a href="/ausbildung" class="back-link">← Zurück zu Ausbildung</a>
                </article>
            </main>
            <Sidebar />
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private Post? post;
    protected override void OnParametersSet() => post = DS.GetPost(Slug);
}
