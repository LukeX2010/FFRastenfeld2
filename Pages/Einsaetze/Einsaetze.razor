@* Einsätze – Übersicht *@
@page "/einsaetze"
@inject DataService DS

<PageTitle>Einsätze 2025 – Freiwillige Feuerwehr Rastenfeld, Niederösterreich</PageTitle>
<PageHero Title="Einsatzchronik FF Rastenfeld" Subtitle="Aktuelle Einsätze der FF Rastenfeld im Bezirk Krems-Land, NÖ – transparent und vollständig dokumentiert" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <div class="feed-filter-bar">
                @foreach (var f in new[]{"Alle","Brand","Technische Hilfe","Unwetter","Gefahrgut","Sonstige"})
                {
                    <button class="filter-pill @(activeFilter==f?"active":"")" @onclick="()=>SetFilter(f)">@f</button>
                }
            </div>

            <div class="einsatz-stats-row">
                <div class="estat"><strong>@all.Count</strong><span>Gesamt</span></div>
                <div class="estat"><strong>@all.Count(e=>e.EinsatzTyp!=null&&e.EinsatzTyp.StartsWith("B"))</strong><span>Brand</span></div>
                <div class="estat"><strong>@all.Count(e=>e.EinsatzTyp!=null&&e.EinsatzTyp.StartsWith("T"))</strong><span>THL</span></div>
                <div class="estat"><strong>@all.Sum(e=>e.EinsatzKraefte??0)</strong><span>Kräfte gesamt</span></div>
            </div>

            @foreach (var p in filtered)
            {
                <PostCard Post="@p" />
            }
            @if (!filtered.Any())
            {
                <p class="empty-msg">Keine Einsätze in dieser Kategorie.</p>
            }
        </main>
        <footer id="site-footer">
    <div class="container footer-grid">
        <div class="footer-col">
            <div class="footer-brand">
                   
                <div>
                    <strong>FF Rastenfeld</strong>
                    <small>Freiwillige Feuerwehr</small>
                </div>
            </div>
            <p>Rastenfeld 178<br/>3532 Rastenfeld<br/>Niederösterreich, Österreich</p>
            <p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a></p>
        </div>

        <div class="footer-col">
            <h4>News</h4>
            <ul>
                <li><a href="/einsaetze">Einsätze</a></li>
                <li><a href="/news">FF-News</a></li>
                <li><a href="/ausbildung">Ausbildung</a></li>
                <li><a href="/feuerwehrjugend">Feuerwehrjugend</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Feuerwehr</h4>
            <ul>
                <li><a href="/chronik">Chronik</a></li>
                <li><a href="/organisation">Organisation</a></li>
                <li><a href="/feuerwehrhaus">Feuerwehrhaus</a></li>
                <li><a href="/fahrzeuge">Fahrzeuge</a></li>
                <li><a href="/galerie">Galerie</a></li>
                <li><a href="/kontakt">Kontakt</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Notruf</h4>
            <a href="tel:122" class="footer-notruf">
                <span>🚨</span>
                <span class="notruf-number">122</span>
            </a>
            <p style="font-size:.82rem;margin-top:.75rem;color:#9CA3AF">Feuerwehr-Notruf<br/>kostenlos · 24/7</p>
            <div style="margin-top:1.25rem;">
                <a href="https://www.facebook.com/profile.php?id=100066674045868" target="_blank" class="social-link">Facebook</a>
                <a href="https://www.instagram.com/ff_rastenfeld?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" class="social-link">Instagram</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <span>© @DateTime.Now.Year Freiwillige Feuerwehr Rastenfeld – Im Dienst der Gemeinschaft seit 1876</span>
            <span>
                <a href="/impressum">Impressum</a> ·
                <a href="/datenschutz">Datenschutz</a>
            </span>
        </div>
    </div>
</footer>

    </div>
</div>

@code {
    private List<Post> all = new();
    private List<Post> filtered = new();
    private string activeFilter = "Alle";

    protected override void OnInitialized()
    {
        all = DS.GetEinsaetze();
        filtered = all;
    }

    private void SetFilter(string f)
    {
        activeFilter = f;
        filtered = f == "Alle" ? all : all.Where(e =>
            f == "Brand" ? e.EinsatzTyp?.StartsWith("B") == true :
            f == "Technische Hilfe" ? e.EinsatzTyp?.StartsWith("T") == true :
            f == "Unwetter" ? e.EinsatzTyp?.StartsWith("S") == true || e.EinsatzTyp?.StartsWith("W") == true :
            f == "Gefahrgut" ? e.EinsatzTyp?.StartsWith("G") == true :
            true).ToList();
    }
}
