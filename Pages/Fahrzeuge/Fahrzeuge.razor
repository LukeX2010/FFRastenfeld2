@* ── Fahrzeuge Übersicht ── *@
@page "/fahrzeuge"
@inject DataService DS

<PageTitle>Fahrzeuge & Ausrüstung – Freiwillige Feuerwehr Rastenfeld, NÖ</PageTitle>
<PageHero Title="Fahrzeuge & Ausrüstung" Subtitle="Der Fuhrpark der FF Rastenfeld – TLF 4000, HLF 2, MTF und Kommandofahrzeug im Überblick" ParentLabel="Feuerwehr" ParentHref="/organisation" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <div class="fahrzeuge-list">
                @foreach (var f in DS.GetFahrzeuge())
                {
                    <div class="fahrzeug-item">
                        <a href="/fahrzeuge/@f.Id" class="fz-img-link">
                            <div class="fz-img">
                                <img src="@($"img/{f.Kuerzel}.jpeg")" class="hero-bg-img" />
                            </div>
                        </a>
                        <div class="fz-body">
                            <h3><a href="/fahrzeuge/@f.Id">@f.Name</a></h3>
                            <div class="fz-meta">
                                <span>🏭 @f.Hersteller</span>
                                <span>📅 Bj. @f.Baujahr</span>
                            </div>
                            <p>@f.Beschreibung</p>
                            <a href="/fahrzeuge/@f.Id" class="read-more">Details ansehen →</a>
                        </div>
                    </div>
                }
            </div>
        </main>
        <footer id="site-footer">
    <div class="container footer-grid">
        <div class="footer-col">
            <div class="footer-brand">
                   
                <div>
                    <strong>FF Rastenfeld</strong>
                    <small>Freiwillige Feuerwehr</small>
                </div>
            </div>
            <p>Rastenfeld 178<br/>3532 Rastenfeld<br/>Niederösterreich, Österreich</p>
            <p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a></p>
        </div>

        <div class="footer-col">
            <h4>News</h4>
            <ul>
                <li><a href="/einsaetze">Einsätze</a></li>
                <li><a href="/news">FF-News</a></li>
                <li><a href="/ausbildung">Ausbildung</a></li>
                <li><a href="/feuerwehrjugend">Feuerwehrjugend</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Feuerwehr</h4>
            <ul>
                <li><a href="/chronik">Chronik</a></li>
                <li><a href="/organisation">Organisation</a></li>
                <li><a href="/feuerwehrhaus">Feuerwehrhaus</a></li>
                <li><a href="/fahrzeuge">Fahrzeuge</a></li>
                <li><a href="/galerie">Galerie</a></li>
                <li><a href="/kontakt">Kontakt</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Notruf</h4>
            <a href="tel:122" class="footer-notruf">
                <span>🚨</span>
                <span class="notruf-number">122</span>
            </a>
            <p style="font-size:.82rem;margin-top:.75rem;color:#9CA3AF">Feuerwehr-Notruf<br/>kostenlos · 24/7</p>
            <div style="margin-top:1.25rem;">
                <a href="https://www.facebook.com/profile.php?id=100066674045868" target="_blank" class="social-link">Facebook</a>
                <a href="https://www.instagram.com/ff_rastenfeld?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" class="social-link">Instagram</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <span>© @DateTime.Now.Year Freiwillige Feuerwehr Rastenfeld – Im Dienst der Gemeinschaft seit 1876</span>
            <span>
                <a href="/impressum">Impressum</a> ·
                <a href="/datenschutz">Datenschutz</a>
            </span>
        </div>
    </div>
</footer>

    </div>
</div>
