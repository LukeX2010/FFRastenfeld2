@page "/feuerwehrhaus"
@inject DataService DS

<PageTitle>Feuerwehrhaus Rastenfeld – Standort & Ausstattung, 3532 Rastenfeld NÖ</PageTitle>
<PageHero Title="Feuerwehrhaus Rastenfeld" Subtitle="Unser Stützpunkt – Rastenfeld 178, 3532 Rastenfeld, Niederösterreich" ParentLabel="Feuerwehr" ParentHref="/organisation" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <article class="post-detail">

                <div class="detail-img">
                   <img src="img/FFhaus.png" class="hero-bg-img"/>
                </div>

                <h2>Unser Feuerwehrhaus</h2>
                <p>Das Feuerwehrhaus der FF Rastenfeld befindet sich in  <a href="https://maps.google.com/?q=Feuerwehrhaus+Rastenfeld+178,3532+Rastenfeld"><strong>Rastenfeld 178</strong></a>. Das 1995 grundlegend sanierte und erweiterte Gebäude bietet Platz für vier Fahrzeuge sowie moderne Infrastruktur für Ausbildung und Verwaltung.</p>

                <h2>Unser Einsatzbereich</h2>
                <p>Die FF Rastenfeld ist zuständig für das gesamte Gemeindegebiet der Marktgemeinde Rastenfeld im Bezirk Krems-Land, Niederösterreich. Zum Einsatzgebiet zählen neben dem Ortszentrum auch alle Katastralgemeinden, die B35, B37 sowie der Stausee Ottenstein.</p>

                <div class="info-grid-2">
                    <div class="ig-item"><span class="ig-label">Fläche</span><strong>~45 km²</strong></div>
                    <div class="ig-item"><span class="ig-label">Einwohner</span><strong>~1.600</strong></div>
                    <div class="ig-item"><span class="ig-label">Seehöhe</span><strong>ca. 520 m</strong></div>
                    <div class="ig-item"><span class="ig-label">Aktive Mitglieder</span><strong>40+</strong></div>
                </div>
                
                <h3>Gemeinden: </h3>    
                    <div class="info-grid-2">
                        <div class="ig-item"><span class="ig-label1">FF Rastenfeld</span></div>
                        <div class="ig-item"><span class="ig-label1">FF Peygarten-Ottenstein</span></div>
                        <div class="ig-item"><span class="ig-label1">FF Marbach im Felde</span></div>
                        <div class="ig-item"><span class="ig-label1">FF Niedergrünbach</span></div>
                        <div class="ig-item"><span class="ig-label1">FF Sperkental</span></div>
                    </div>
            </article>
        </main>
        <aside class="sidebar">
            <!-- Suche -->

            <!-- Letzter Einsatz -->
            <div class="sidebar-widget sidebar-widget--red">
                <h3>⚡ Letzter Einsatz</h3>
                @{var last = DS.GetEinsaetze().FirstOrDefault();}
                @if (last != null)
                {
                <p class="sidebar-einsatz-typ">@last.EinsatzTyp</p>
                <p class="sidebar-einsatz-title"><a href="/einsaetze/@last.Slug">@last.Titel</a></p>
                <time>@last.Datum.ToString("dd.MM.yyyy – HH:mm") Uhr</time>
                }
            </div>

            <!-- Kategorien -->
            <div class="sidebar-widget">
                <h3>Kategorien</h3>
                <ul class="sidebar-cats">
                    <li><a href="/einsaetze">Einsätze <span>@DS.GetByKategorie("Einsätze").Count</span></a></li>
                    <li><a href="/news">FF-News <span>@DS.GetByKategorie("FF-News").Count</span></a></li>
                    <li><a href="/ausbildung">Ausbildung <span>@DS.GetByKategorie("Ausbildung").Count</span></a></li>
                    <li><a href="/feuerwehrjugend">Feuerwehrjugend <span>@DS.GetByKategorie("Feuerwehrjugend").Count</span></a></li>
                </ul>
            </div>

            <!-- Links -->
            <div class="sidebar-widget">
                <h3>Links</h3>
                <ul class="sidebar-links">
                    <li><a href="https://www.noelfv.at" target="_blank">NÖ Landesfeuerwehrverband</a></li>
                    <li><a href="https://www.bfk-krems.at" target="_blank">BFK Krems-Land</a></li>
                    <li><a href="https://www.noelfv.at/wastl" target="_blank">WASTL Einsatzmonitor</a></li>
                    <li><a href="https://www.noelfv.at/lfws" target="_blank">NÖ Landesfeuerwehrschule</a></li>
                    <li><a href="https://www.rastenfeld.at" target="_blank">Marktgemeinde Rastenfeld</a></li>
                </ul>
            </div>

            <!-- Mitglied werden Banner -->
            <div class="sidebar-widget sidebar-widget--join">
                <p>🧑‍🚒 <strong>Werde Mitglied!</strong></p>
                <p>Du möchtest helfen? Wir freuen uns über jede Verstärkung!</p>
                <a href="/kontakt" class="btn btn-primary" style="width:100%;text-align:center;margin-top:.5rem;">Jetzt mitmachen</a>
            </div>
        </aside>

    </div>
</div>
