@* ── News Detail ── *@
@page "/news/{Slug}"
@inject DataService DS
@inject IJSRuntime JS

<PageTitle>@(post?.Titel ?? "Beitrag") – Freiwillige Feuerwehr Rastenfeld, NÖ</PageTitle>

@if (post is null)
{
    <div class="container" style="padding:4rem 1.5rem;text-align:center">
        <p>Beitrag nicht gefunden. <a href="/news">← Zurück</a></p>
    </div>
}
else
{
    <PageHero Title="@post.Titel" ParentLabel="FF-News" ParentHref="/news"/>
    <div class="site-body container">
        <div class="content-with-sidebar">
            <main class="main-feed">
                <article class="post-detail">
                    <div class="detail-meta">
                        <span class="post-card-kat post-card-kat--ff-news">FF-News</span>
                        <time>@post.Datum.ToString("d. MMMM yyyy")</time>
                    </div>
                    <div class="detail-img">
                        <img src="@($"img/{post.Slug}.jpeg")" class="hero-bg-img" alt="@post.Titel"/>
                    </div>
                    <div class="detail-body"><p>@post.Volltext</p></div>

                    @if (post.Bilder != null && post.Bilder.Count > 0)
                    {
                        <div class="ff-carousel">

                            @* Bilder *@
                            <div class="ff-carousel__track">
                                @for (int i = 0; i < post.Bilder.Count; i++)
                                {
                                    <div class="ff-carousel__slide @(i == currentIndex ? "ff-carousel__slide--active" : "")">
                                        <img src="img/@post.Bilder[i]" alt="Bild @(i + 1)" >
                                        <br/>
                                    </div>
                                }
                            </div>

                            @* Pfeile *@
                            <button class="ff-carousel__btn ff-carousel__btn--prev"
                                    @onclick="Prev" aria-label="Zurück">&#8249;</button>
                            <button class="ff-carousel__btn ff-carousel__btn--next"
                                    @onclick="Next" aria-label="Weiter">&#8250;</button>

                            @* Punkte *@
                            <div class="ff-carousel__dots">
                                @for (int i = 0; i < post.Bilder.Count; i++)
                                {
                                    var idx = i;
                                    <button class="ff-carousel__dot @(i == currentIndex ? "ff-carousel__dot--active" : "")"
                                            @onclick="() => GoTo(idx)"
                                            aria-label="Slide @(i + 1)">
                                    </button>
                                }
                            </div>

                            @* Zähler *@
                            <div class="ff-carousel__counter">
                                @(currentIndex + 1) / @post.Bilder.Count
                            </div>

                        </div>
                    }

                    <a href="/news" class="back-link">← Zurück zu FF-News</a>
                </article>
            </main>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private Post? post;
    private int currentIndex = 0;

    protected override void OnParametersSet()
    {
        post = DS.GetPost(Slug);
        currentIndex = 0;
    }

    private void Next()
    {
        if (post?.Bilder is null) return;
        currentIndex = (currentIndex + 1) % post.Bilder.Count;
    }

    private void Prev()
    {
        if (post?.Bilder is null) return;
        currentIndex = (currentIndex - 1 + post.Bilder.Count) % post.Bilder.Count;
    }

    private void GoTo(int index) => currentIndex = index;
}