@page "/einsaetze/{Slug}"
@inject DataService DS
@inject NavigationManager Nav

<PageTitle>@(post?.Titel ?? "Einsatz") – FF Rastenfeld, Niederösterreich</PageTitle>

@if (post is null)
{
    <div class="container" style="padding:4rem 1.5rem;text-align:center">
        <p>Einsatz nicht gefunden. <a href="/einsaetze">← Zurück</a></p>
    </div>
}
else
{
    <PageHero Title="@post.Titel" ParentLabel="Einsätze" ParentHref="/einsaetze" />

    <div class="site-body container">
        <div class="content-with-sidebar">
            <main class="main-feed">
                <article class="post-detail">
                    <!-- Meta -->
                    <div class="detail-meta">
                        <span class="post-card-kat post-card-kat--einsa-tze">Einsätze</span>
                        <time>@post.Datum.ToString("dddd, d. MMMM yyyy – HH:mm") Uhr</time>
                    </div>

                    <!-- Einsatz-Infobox -->
                    <div class="einsatz-infobox">
                        <div class="eib-row"><span class="eib-label">Einsatztyp</span><span>@post.EinsatzTyp</span></div>
                        <div class="eib-row"><span class="eib-label">Einsatzort</span><span>📍 @post.EinsatzOrt</span></div>
                        <div class="eib-row"><span class="eib-label">Alarmzeit</span><span>🕐 @post.EinsatzZeit</span></div>
                        <div class="eib-row"><span class="eib-label">Einsatzkräfte</span><span>👥 @post.EinsatzKraefte Personen</span></div>
                    </div>

                    <!-- Platzhalterbild -->
                    <div class="detail-img">
                        <img src="@($"img/{post.Slug}.jpeg")" class="hero-bg-img" />
                    </div>

                    <!-- Volltext -->
                    <div class="detail-body">
                        <p>@post.Volltext</p>
                    </div>

                    <a href="/einsaetze" class="back-link">← Zurück zur Einsatzübersicht</a>
                </article>
            </main>
            <footer id="site-footer">
    <div class="container footer-grid">
        <div class="footer-col">
            <div class="footer-brand">
                   
                <div>
                    <strong>FF Rastenfeld</strong>
                    <small>Freiwillige Feuerwehr</small>
                </div>
            </div>
            <p>Rastenfeld 178<br/>3532 Rastenfeld<br/>Niederösterreich, Österreich</p>
            <p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a></p>
        </div>

        <div class="footer-col">
            <h4>News</h4>
            <ul>
                <li><a href="/einsaetze">Einsätze</a></li>
                <li><a href="/news">FF-News</a></li>
                <li><a href="/ausbildung">Ausbildung</a></li>
                <li><a href="/feuerwehrjugend">Feuerwehrjugend</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Feuerwehr</h4>
            <ul>
                <li><a href="/chronik">Chronik</a></li>
                <li><a href="/organisation">Organisation</a></li>
                <li><a href="/feuerwehrhaus">Feuerwehrhaus</a></li>
                <li><a href="/fahrzeuge">Fahrzeuge</a></li>
                <li><a href="/galerie">Galerie</a></li>
                <li><a href="/kontakt">Kontakt</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Notruf</h4>
            <a href="tel:122" class="footer-notruf">
                <span>🚨</span>
                <span class="notruf-number">122</span>
            </a>
            <p style="font-size:.82rem;margin-top:.75rem;color:#9CA3AF">Feuerwehr-Notruf<br/>kostenlos · 24/7</p>
            <div style="margin-top:1.25rem;">
                <a href="https://www.facebook.com/profile.php?id=100066674045868" target="_blank" class="social-link">Facebook</a>
                <a href="https://www.instagram.com/ff_rastenfeld?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" class="social-link">Instagram</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <span>© @DateTime.Now.Year Freiwillige Feuerwehr Rastenfeld – Im Dienst der Gemeinschaft seit 1876</span>
            <span>
                <a href="/impressum">Impressum</a> ·
                <a href="/datenschutz">Datenschutz</a>
            </span>
        </div>
    </div>
</footer>

        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private Post? post;

    protected override void OnParametersSet()
    {
        post = DS.GetPost(Slug);
    }
}
