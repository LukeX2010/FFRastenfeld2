@page "/mannschaft"
@inject DataService DS

<PageTitle>Mannschaft & Kommando – Freiwillige Feuerwehr Rastenfeld, NÖ</PageTitle>
<PageHero Title="Mannschaft & Kommando" Subtitle="40+ aktive Mitglieder der FF Rastenfeld im Einsatz für Rastenfeld und Umgebung, Bezirk Krems-Land" ParentLabel="Feuerwehr" ParentHref="/organisation" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <article class="post-detail">

                <!-- Einsatzbereich -->
                

                <!-- Kommando -->
                <h2 style="margin-top:2.5rem;">Feuerwehrkommando</h2>
                <p>Das Kommando der FF Rastenfeld wird alle fünf Jahre bei der Vollversammlung gewählt und trägt die Gesamtverantwortung für Einsatz, Ausbildung und Verwaltung der Feuerwehr.</p>

                <div class="kommando-grid">
                    @foreach (var m in DS.GetMitglieder().Where(m => m.IstFuehrung))
                    {
                        <div class="kommando-card">
                            <div class="kk-avatar">🧑‍🚒</div>
                            <div class="kk-info">
                                <span class="kk-grad">@m.Dienstgrad</span>
                                <strong>@m.Name</strong>
                                <span class="kk-funk">@m.Funktion</span>
                                <span class="kk-seit">Dabei seit @m.EintriebAb</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Alle Mitglieder -->
                <h2 style="margin-top:2.5rem;">Aktive Mannschaft</h2>
                <div class="mitglieder-table">
                    <table>
                        <thead>
                            <tr><th>Name</th><th>Dienstgrad</th><th>Funktion</th><th>Dabei seit</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var m in DS.GetMitglieder())
                            {
                                <tr>
                                    <td>@m.Name</td>
                                    <td>@m.Dienstgrad</td>
                                    <td>@m.Funktion</td>
                                    <td>@m.EintriebAb</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </article>
        </main>
       <footer id="site-footer">
    <div class="container footer-grid">
        <div class="footer-col">
            <div class="footer-brand">
                   
                <div>
                    <strong>FF Rastenfeld</strong>
                    <small>Freiwillige Feuerwehr</small>
                </div>
            </div>
            <p>Rastenfeld 178<br/>3532 Rastenfeld<br/>Niederösterreich, Österreich</p>
            <p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a></p>
        </div>

        <div class="footer-col">
            <h4>News</h4>
            <ul>
                <li><a href="/einsaetze">Einsätze</a></li>
                <li><a href="/news">FF-News</a></li>
                <li><a href="/ausbildung">Ausbildung</a></li>
                <li><a href="/feuerwehrjugend">Feuerwehrjugend</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Feuerwehr</h4>
            <ul>
                <li><a href="/chronik">Chronik</a></li>
                <li><a href="/organisation">Organisation</a></li>
                <li><a href="/feuerwehrhaus">Feuerwehrhaus</a></li>
                <li><a href="/fahrzeuge">Fahrzeuge</a></li>
                <li><a href="/galerie">Galerie</a></li>
                <li><a href="/kontakt">Kontakt</a></li>
            </ul>
        </div>

        <div class="footer-col">
            <h4>Notruf</h4>
            <a href="tel:122" class="footer-notruf">
                <span>🚨</span>
                <span class="notruf-number">122</span>
            </a>
            <p style="font-size:.82rem;margin-top:.75rem;color:#9CA3AF">Feuerwehr-Notruf<br/>kostenlos · 24/7</p>
            <div style="margin-top:1.25rem;">
                <a href="https://www.facebook.com/profile.php?id=100066674045868" target="_blank" class="social-link">Facebook</a>
                <a href="https://www.instagram.com/ff_rastenfeld?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" class="social-link">Instagram</a>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-inner">
            <span>© @DateTime.Now.Year Freiwillige Feuerwehr Rastenfeld – Im Dienst der Gemeinschaft seit 1876</span>
            <span>
                <a href="/impressum">Impressum</a> ·
