@* Einsätze – Übersicht *@
@page "/einsaetze"
@inject DataService DS

<PageTitle>Einsätze 2025 – Freiwillige Feuerwehr Rastenfeld, Niederösterreich</PageTitle>
<PageHero Title="Einsatz chronik FF Rastenfeld" Subtitle="Aktuelle Einsätze der FF Rastenfeld im Bezirk Krems-Land, NÖ" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <div class="feed-filter-bar">
                @foreach (var f in new[]{"Alle","Brand","Technische Hilfe","Unwetter","Gefahrgut","Sonstige"})
                {
                    <button class="filter-pill @(activeFilter==f?"active":"")" @onclick="()=>SetFilter(f)">@f</button>
                }
            </div>

            <div class="einsatz-stats-row">
                <div class="estat"><strong>@all.Count</strong><span>Gesamt</span></div>
                <div class="estat"><strong>@all.Count(e=>e.EinsatzTyp!=null&&e.EinsatzTyp.StartsWith("B"))</strong><span>Brand</span></div>
                <div class="estat"><strong>@all.Count(e=>e.EinsatzTyp!=null&&e.EinsatzTyp.StartsWith("T"))</strong><span>THL</span></div>
                <div class="estat"><strong>@all.Sum(e=>e.EinsatzKraefte??0)</strong><span>Kräfte gesamt</span></div>
            </div>

            @foreach (var p in filtered)
            {
                <PostCard Post="@p" />
            }
            @if (!filtered.Any())
            {
                <p class="empty-msg">Keine Einsätze in dieser Kategorie.</p>
            }
        </main>
               <aside class="sidebar">
            <!-- Suche -->

            <!-- Letzter Einsatz -->
            <div class="sidebar-widget sidebar-widget--red">
                <h3>⚡ Letzter Einsatz</h3>
                @{var last = DS.GetEinsaetze().FirstOrDefault();}
                @if (last != null)
                {
                    <p class="sidebar-einsatz-typ">@last.EinsatzTyp</p>
                    <p class="sidebar-einsatz-title"><a href="/einsaetze/@last.Slug">@last.Titel</a></p>
                    <time>@last.Datum.ToString("dd.MM.yyyy – HH:mm") Uhr</time>
                }
            </div>

            <!-- Kategorien -->
            <div class="sidebar-widget">
                <h3>Kategorien</h3>
                <ul class="sidebar-cats">
                    <li><a href="/einsaetze">Einsätze <span>@DS.GetByKategorie("Einsätze").Count</span></a></li>
                    <li><a href="/news">FF-News <span>@DS.GetByKategorie("FF-News").Count</span></a></li>
                    <li><a href="/ausbildung">Ausbildung <span>@DS.GetByKategorie("Ausbildung").Count</span></a></li>
                    <li><a href="/feuerwehrjugend">Feuerwehrjugend <span>@DS.GetByKategorie("Feuerwehrjugend").Count</span></a></li>
                </ul>
            </div>

            <!-- Links -->
            <div class="sidebar-widget">
                <h3>Links</h3>
                <ul class="sidebar-links">
                    <li><a href="https://www.noelfv.at" target="_blank">NÖ Landesfeuerwehrverband</a></li>
                    <li><a href="https://www.bfk-krems.at" target="_blank">BFK Krems-Land</a></li>
                    <li><a href="https://www.noelfv.at/wastl" target="_blank">WASTL Einsatzmonitor</a></li>
                    <li><a href="https://www.noelfv.at/lfws" target="_blank">NÖ Landesfeuerwehrschule</a></li>
                    <li><a href="https://www.rastenfeld.at" target="_blank">Marktgemeinde Rastenfeld</a></li>
                </ul>
            </div>

            <!-- Mitglied werden Banner -->
            <div class="sidebar-widget sidebar-widget--join">
                <p>🧑‍🚒 <strong>Werde Mitglied!</strong></p>
                <p>Du möchtest helfen? Wir freuen uns über jede Verstärkung!</p>
                <a href="/kontakt" class="btn btn-primary" style="width:100%;text-align:center;margin-top:.5rem;">Jetzt mitmachen</a>
            </div>
        </aside>


    </div>
</div>

@code {
    private List<Post> all = new();
    private List<Post> filtered = new();
    private string activeFilter = "Alle";

    protected override void OnInitialized()
    {
        all = DS.GetEinsaetze();
        filtered = all;
    }

    private void SetFilter(string f)
    {
        activeFilter = f;
        filtered = f == "Alle" ? all : all.Where(e =>
            f == "Brand" ? e.EinsatzTyp?.StartsWith("B") == true :
            f == "Technische Hilfe" ? e.EinsatzTyp?.StartsWith("T") == true :
            f == "Unwetter" ? e.EinsatzTyp?.StartsWith("S") == true || e.EinsatzTyp?.StartsWith("W") == true :
            f == "Gefahrgut" ? e.EinsatzTyp?.StartsWith("G") == true :
            true).ToList();
    }
}
