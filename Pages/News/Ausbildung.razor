@* ── Ausbildung Übersicht ── *@
@page "/ausbildung"
@inject DataService DS

<PageTitle>Ausbildung & Übungen – Freiwillige Feuerwehr Rastenfeld, Bezirk Krems</PageTitle>
<PageHero Title="Ausbildung & Übungen" Subtitle="Kurse, Lehrgänge und Übungen der FF Rastenfeld – bestens ausgebildet für jeden Einsatz" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            @foreach (var p in DS.GetByKategorie("Ausbildung"))
            {
                <PostCard Post="@p" />
            }
        </main>

    </div>
</div>
