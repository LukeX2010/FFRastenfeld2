@page "/kontakt"
@inject DataService DS

<PageTitle>Kontakt – Freiwillige Feuerwehr Rastenfeld, 3532 Rastenfeld, NÖ</PageTitle>
<PageHero Title="Kontakt & Anfahrt" Subtitle="FF Rastenfeld · Rastenfeld 178 · 3532 Rastenfeld · Notruf 122"/>

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <article class="post-detail">

                <!-- Notruf -->
                <div class="notruf-box">
                    <div class="nb-icon">🚨</div>
                    <div>
                        <h3>Im Notfall: 122 rufen!</h3>
                        <p>Der Feuerwehr-Notruf 122 ist kostenlos und rund um die Uhr erreichbar.<br/>Bitte nur im
                            echten Notfall verwenden!</p>
                        <a href="tel:122" class="btn btn-danger">122 anrufen</a>
                    </div>
                </div>

                <div class="kontakt-cols">
                    <!-- Daten -->
                    <div>
                        <h2>Kontaktdaten</h2>
                        <div class="kdaten">
                            <div class="kd-row">
                                <span>📍</span>
                                <div><strong>Adresse</strong>
                                    <p>FF Rastenfeld<br/>Rastenfeld 178<br/>3532 Rastenfeld, NÖ</p></div>
                            </div>
                            <div class="kd-row">
                                <span>📧</span>
                                <div><strong>E-Mail</strong>
                                    <p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a>
                                    </p></div>
                            </div>
                            <div class="kd-row">
                                <span>🏛️</span>
                                <div><strong>Übergeordnet</strong>
                                    <p>BFK Krems-Land<br/>NÖ Landesfeuerwehrverband</p></div>
                            </div>
                        </div>
                        
                        <!-- Spenden Sektion -->
                        <div class="spenden-box">
                            <h2>Unterstützen Sie uns</h2>
                            <p>Ihre Spende hilft uns bei der Anschaffung von Ausrüstung und modernem Gerät.</p>
                            <div class="spenden-action">
                                <span class="heart-icon">❤️</span>
                                <a href="/spenden" class="btn btn-warning btn-lg">Jetzt online spenden</a>
                            </div>
                        </div>
                        
                    </div>


                </div>


                <div class="map-wrap">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2649.5!2d15.3399094!3d48.5707422!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4772ed001828076b%3A0x7126927fdc0a1cf3!2sFreiwillige%20Feuerwehr%20Rastenfeld!5e0!3m2!1sde!2sat!4v1"
                        width="100%"
                        height="420"
                        style="border:0; border-radius: 8px; display:block;"
                        allowfullscreen
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Standort FF Rastenfeld">
                    </iframe>
                </div>


            </article>
        </main> 
        <aside class="sidebar">
            <!-- Suche -->

            <!-- Letzter Einsatz -->
            <div class="sidebar-widget sidebar-widget--red">
                <h3>⚡ Letzter Einsatz</h3>
                @{var last = DS.GetEinsaetze().FirstOrDefault();}
                @if (last != null)
                {
                    <p class="sidebar-einsatz-typ">@last.EinsatzTyp</p>
                    <p class="sidebar-einsatz-title"><a href="/einsaetze/@last.Slug">@last.Titel</a></p>
                    <time>@last.Datum.ToString("dd.MM.yyyy – HH:mm") Uhr</time>
                }
            </div>

            <!-- Kategorien -->
            <div class="sidebar-widget">
                <h3>Kategorien</h3>
                <ul class="sidebar-cats">
                    <li><a href="/einsaetze">Einsätze <span>@DS.GetByKategorie("Einsätze").Count</span></a></li>
                    <li><a href="/news">FF-News <span>@DS.GetByKategorie("FF-News").Count</span></a></li>
                    <li><a href="/ausbildung">Ausbildung <span>@DS.GetByKategorie("Ausbildung").Count</span></a></li>
                    <li><a href="/feuerwehrjugend">Feuerwehrjugend <span>@DS.GetByKategorie("Feuerwehrjugend").Count</span></a></li>
                </ul>
            </div>

            <!-- Links -->
            <div class="sidebar-widget">
                <h3>Links</h3>
                <ul class="sidebar-links">
                    <li><a href="https://www.noelfv.at" target="_blank">NÖ Landesfeuerwehrverband</a></li>
                    <li><a href="https://www.bfk-krems.at" target="_blank">BFK Krems-Land</a></li>
                    <li><a href="https://www.noelfv.at/wastl" target="_blank">WASTL Einsatzmonitor</a></li>
                    <li><a href="https://www.noelfv.at/lfws" target="_blank">NÖ Landesfeuerwehrschule</a></li>
                    <li><a href="https://www.rastenfeld.at" target="_blank">Marktgemeinde Rastenfeld</a></li>
                </ul>
            </div>

            <!-- Mitglied werden Banner -->
            <div class="sidebar-widget sidebar-widget--join">
                <p>🧑‍🚒 <strong>Werde Mitglied!</strong></p>
                <p>Du möchtest helfen? Wir freuen uns über jede Verstärkung!</p>
                <a href="/kontakt" class="btn btn-primary" style="width:100%;text-align:center;margin-top:.5rem;">Jetzt mitmachen</a>
            </div>
        </aside>
    </div>
</div>

@code {



}
