@page "/chronik"
@inject DataService DS
<PageTitle>Chronik seit 1871 – Geschichte der Freiwilligen Feuerwehr Rastenfeld, NÖ</PageTitle>
<PageHero Title="Geschichte seit 1871" Subtitle="148 Jahre Freiwillige Feuerwehr Rastenfeld – Von der Gründung bis heute" ParentLabel="Feuerwehr" ParentHref="/organisation" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <article class="post-detail">
                <h2>Von der Gründung bis heute</h2>
                <p>Die Freiwillige Feuerwehr Rastenfeld wurde im Jahr <strong>1871</strong> gegründet. In den über 148 Jahren ihres Bestehens hat sie sich von einer kleinen Handspritzentruppe zu einer modernen, vollausgerüsteten Feuerwehr mit 40+ aktiven Mitgliedern entwickelt.</p>

                <div class="timeline-list">
                    @foreach (var e in events)
                    {
                        <div class="tl-item">
                            <div class="tl-year">@e.Jahr</div>
                            <div class="tl-content">
                                <h4>@e.Titel</h4>
                                <p>@e.Text</p>
                            </div>
                        </div>
                    }
                </div>
            </article>
        </main>
        <aside class="sidebar">
            <!-- Suche -->

            <!-- Letzter Einsatz -->
            <div class="sidebar-widget sidebar-widget--red">
                <h3>⚡ Letzter Einsatz</h3>
                @{var last = DS.GetEinsaetze().FirstOrDefault();}
                @if (last != null)
                {
                <p class="sidebar-einsatz-typ">@last.EinsatzTyp</p>
                <p class="sidebar-einsatz-title"><a href="/einsaetze/@last.Slug">@last.Titel</a></p>
                <time>@last.Datum.ToString("dd.MM.yyyy – HH:mm") Uhr</time>
                }
            </div>

            <!-- Kategorien -->
            <div class="sidebar-widget">
                <h3>Kategorien</h3>
                <ul class="sidebar-cats">
                    <li><a href="/einsaetze">Einsätze <span>@DS.GetByKategorie("Einsätze").Count</span></a></li>
                    <li><a href="/news">FF-News <span>@DS.GetByKategorie("FF-News").Count</span></a></li>
                    <li><a href="/ausbildung">Ausbildung <span>@DS.GetByKategorie("Ausbildung").Count</span></a></li>
                    <li><a href="/feuerwehrjugend">Feuerwehrjugend <span>@DS.GetByKategorie("Feuerwehrjugend").Count</span></a></li>
                </ul>
            </div>

            <!-- Links -->
            <div class="sidebar-widget">
                <h3>Links</h3>
                <ul class="sidebar-links">
                    <li><a href="https://www.noelfv.at" target="_blank">NÖ Landesfeuerwehrverband</a></li>
                    <li><a href="https://www.bfk-krems.at" target="_blank">BFK Krems-Land</a></li>
                    <li><a href="https://www.noelfv.at/wastl" target="_blank">WASTL Einsatzmonitor</a></li>
                    <li><a href="https://www.noelfv.at/lfws" target="_blank">NÖ Landesfeuerwehrschule</a></li>
                    <li><a href="https://www.rastenfeld.at" target="_blank">Marktgemeinde Rastenfeld</a></li>
                </ul>
            </div>

            <!-- Mitglied werden Banner -->
            <div class="sidebar-widget sidebar-widget--join">
                <p>🧑‍🚒 <strong>Werde Mitglied!</strong></p>
                <p>Du möchtest helfen? Wir freuen uns über jede Verstärkung!</p>
                <a href="/kontakt" class="btn btn-primary" style="width:100%;text-align:center;margin-top:.5rem;">Jetzt mitmachen</a>
            </div>
        </aside>

    </div>
</div>

@code {
    record ChronikEvent(int Jahr, string Titel, string Text);

    private List<ChronikEvent> events = new()
    {
        new(1871, "Gründung der Freiwilligen Feuerwehr Rastenfeld", "Am 12. April 1871 wird die Freiwillige Feuerwehr Rastenfeld mit 18 Gründungsmitgliedern ins Leben gerufen. Als erste Ausrüstung stehen zwei Handspritzen zur Verfügung."),
        new(1892, "Erste Handdruckspritze", "Anschaffung einer leistungsstärkeren Handdruckspritze mit 200 Liter Behälter. Der Mannschaftsstand wächst auf 32 Mann."),
        new(1924, "Erste Motorspritze", "Die FF Rastenfeld erhält ihre erste motorgetriebene Feuerspritze – ein großer Fortschritt in der Brandbekämpfung."),
        new(1938, "Neues Gerätehaus", "Errichtung eines neuen Gerätehauses am Ortsrand. Erstmals Platz für zwei Fahrzeuge und eine Werkstatt."),
        new(1963, "Erstes Löschfahrzeug", "Indienststellung des ersten motorisierten Löschfahrzeuges (LF 8). Die Einsatzfähigkeit verbessert sich deutlich."),
        new(1978, "100 Jahre FF Rastenfeld", "Großes Festwochenende zum 100-Jahr-Jubiläum mit Bezirksbewerb und Festumzug. Über 2.000 Besucher aus der Region."),
        new(1995, "Neubau Feuerwehrhaus", "Erweiterung und Modernisierung des Feuerwehrhauses. Vier Fahrzeugstellplätze, Schulungsraum, Atemschutzübungsanlage."),
        new(2008, "Erstmals weibliche Mitglieder", "Die FF Rastenfeld öffnet sich für weibliche Mitglieder. Als erste Feuerwehrfrau tritt Maria Huber der Wehr bei."),
        new(2016, "Neues HLF 2", "Übergabe des neuen Hilfeleistungsfahrzeuges HLF 2 (Rosenbauer / Mercedes-Benz). Modernste Technik für Brandeinsätze und THL."),
        new(2019, "Neues TLF 4000", "Das leistungsstarke Tanklöschfahrzeug TLF 4000 verstärkt den Fuhrpark. Besonders für Waldbrände und wasserarme Gebiete wertvoll."),
        new(2024, "148 Jahre FF Rastenfeld", "Die FF Rastenfeld blickt auf 148 erfolgreiche Jahre zurück. Aktuell 40+ aktive Mitglieder, 4 Einsatzfahrzeuge, modernste Ausrüstung."),
    };
}
