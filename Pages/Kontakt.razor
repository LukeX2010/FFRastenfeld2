@page "/kontakt"

<PageTitle>Kontakt – FF Rastenfeld</PageTitle>
<PageHero Title="Kontakt" Subtitle="Schreib uns – oder ruf bei Notfall 122 an" />

<div class="site-body container">
    <div class="content-with-sidebar">
        <main class="main-feed">
            <article class="post-detail">

                <!-- Notruf -->
                <div class="notruf-box">
                    <div class="nb-icon">🚨</div>
                    <div>
                        <h3>Im Notfall: 122 rufen!</h3>
                        <p>Der Feuerwehr-Notruf 122 ist kostenlos und rund um die Uhr erreichbar.<br/>Bitte nur im echten Notfall verwenden!</p>
                        <a href="tel:122" class="btn btn-danger">122 anrufen</a>
                    </div>
                </div>

                <div class="kontakt-cols">
                    <!-- Daten -->
                    <div>
                        <h2>Kontaktdaten</h2>
                        <div class="kdaten">
                            <div class="kd-row">
                                <span>📍</span>
                                <div><strong>Adresse</strong><p>FF Rastenfeld<br/>Rastenfeld 178<br/>3532 Rastenfeld, NÖ</p></div>
                            </div>
                            <div class="kd-row">
                                <span>📧</span>
                                <div><strong>E-Mail</strong><p><a href="mailto:rastenfeld@feuerwehr.gv.at">rastenfeld&#64;feuerwehr.gv.at</a></p></div>
                            </div>
                            <div class="kd-row">
                                <span>🏛️</span>
                                <div><strong>Übergeordnet</strong><p>BFK Krems-Land<br/>NÖ Landesfeuerwehrverband</p></div>
                            </div>
                        </div>
                    </div>

                    
                </div>

                
                <div class="map-wrap">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2649.5!2d15.3399094!3d48.5707422!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4772ed001828076b%3A0x7126927fdc0a1cf3!2sFreiwillige%20Feuerwehr%20Rastenfeld!5e0!3m2!1sde!2sat!4v1"
                        width="100%"
                        height="420"
                        style="border:0; border-radius: 8px; display:block;"
                        allowfullscreen
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Standort FF Rastenfeld">
                    </iframe>
                </div>
                

            </article>
        </main>
        <Sidebar />
    </div>
</div>

